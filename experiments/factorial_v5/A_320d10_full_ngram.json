{
  "name": "A_320d10_full_ngram",

  // Factorial cell A: 320d × 10 blocks (= v4 config 01) but with full-dim
  // bigram + trigram embeddings (4096 vocab, 384 dim — same as v4 config 04).
  // Isolates the "full n-gram" change from v4 config 01 → 04 transition.
  // If A wins ≈ config 04: the n-gram embedding capacity is doing the work.
  // If A loses to config 04: the width/depth swap is what matters.
  "model_dim": 320,
  "vocab_size": 8192,
  "seq_len": 1024,
  "parallel_residual": true,
  "logit_softcap": 30.0,
  "bigram_vocab_size": 4096,
  "bigram_dim": 384,
  "trigram_vocab_size": 4096,
  "trigram_dim": 384,
  "blocks": [
    {"type": "plain", "heads": 4, "qk_gain": 5.25, "weight_group": "attn_a"},
    {"type": "swiglu", "weight_group": "ffn_a"},
    {"type": "plain", "heads": 4, "qk_gain": 5.25, "weight_group": "attn_b"},
    {"type": "swiglu", "weight_group": "ffn_b"},
    {"type": "plain", "heads": 4, "qk_gain": 5.25, "weight_group": "attn_c"},
    {"type": "swiglu", "weight_group": "ffn_c"},
    {"type": "plain", "heads": 4, "qk_gain": 5.25, "weight_group": "attn_a"},
    {"type": "swiglu", "weight_group": "ffn_a"},
    {"type": "plain", "heads": 4, "qk_gain": 5.25, "weight_group": "attn_b"},
    {"type": "swiglu", "weight_group": "ffn_b"}
  ],
  "training": {
    "steps": 10000, "lr": 1e-3, "grad_clip": 1.0, "weight_decay": 0.04,
    "seed": 42, "batch_tokens": 4096,
    "optimizer": "muon", "muon_momentum": 0.95, "muon_backend_steps": 5,
    "newton_schulz_variant": "polar_express", "min_lr_fraction": 0.10,
    "qat": "int6", "qat_start": 7000,
    "swa_start": 7000, "swa_decay": 0.997, "swa_interval": 50
  }
}
