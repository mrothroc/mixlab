{
  "name": "02_mamba_optimized",

  // Mamba3 stack with everything mixlab can apply: Muon, late QAT, SWA,
  // logit softcap, bigrams, SP-8192. No depth recurrence yet — that's
  // config 03. No parallel_residual (mamba blocks aren't allowed in
  // parallel_residual pairs).
  "model_dim": 320,
  "vocab_size": 8192,
  "seq_len": 1024,
  "logit_softcap": 30.0,
  "bigram_vocab_size": 3072,
  "bigram_dim": 80,
  "blocks": [
    {"type": "mamba3"},
    {"type": "swiglu"},
    {"type": "mamba3"},
    {"type": "swiglu"},
    {"type": "mamba3"},
    {"type": "swiglu"},
    {"type": "mamba3"},
    {"type": "swiglu"},
    {"type": "mamba3"},
    {"type": "swiglu"}
  ],
  "training": {
    "steps": 10000,
    "lr": 1e-3,
    "grad_clip": 1.0,
    "weight_decay": 0.04,
    "seed": 42,
    "batch_tokens": 4096,
    "optimizer": "muon",
    "muon_momentum": 0.95,
    "muon_backend_steps": 5,
    "qat": "int6",
    "qat_start": 7000,
    "swa_start": 7000,
    "swa_decay": 0.997,
    "swa_interval": 50
  }
}
