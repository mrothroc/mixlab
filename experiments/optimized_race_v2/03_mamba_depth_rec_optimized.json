{
  "name": "03_mamba_depth_rec_optimized",

  // The novel combo from race v1, now with the full optimization stack:
  // depth-recurrent mamba3 + Muon + late QAT + SWA + softcap + bigrams +
  // SP-8192. 10 executed blocks built from 3 unique mamba3 + 3 unique FFN.
  "model_dim": 320,
  "vocab_size": 8192,
  "seq_len": 1024,
  "logit_softcap": 30.0,
  "bigram_vocab_size": 3072,
  "bigram_dim": 80,
  "blocks": [
    {"type": "mamba3", "weight_group": "ssm_a"},
    {"type": "swiglu", "weight_group": "ffn_a"},
    {"type": "mamba3", "weight_group": "ssm_b"},
    {"type": "swiglu", "weight_group": "ffn_b"},
    {"type": "mamba3", "weight_group": "ssm_c"},
    {"type": "swiglu", "weight_group": "ffn_c"},
    {"type": "mamba3", "weight_group": "ssm_a"},
    {"type": "swiglu", "weight_group": "ffn_a"},
    {"type": "mamba3", "weight_group": "ssm_b"},
    {"type": "swiglu", "weight_group": "ffn_b"}
  ],
  "training": {
    "steps": 10000,
    "lr": 1e-3,
    "grad_clip": 1.0,
    "weight_decay": 0.04,
    "seed": 42,
    "batch_tokens": 4096,
    "optimizer": "muon",
    "muon_momentum": 0.95,
    "muon_backend_steps": 5,
    "qat": "int6",
    "qat_start": 7000,
    "swa_start": 7000,
    "swa_decay": 0.997,
    "swa_interval": 50
  }
}
