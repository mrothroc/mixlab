{
  "name": "02_depth_recurrent",

  // Same compute as baseline, but 3 unique blocks shared 2x via weight_group.
  // Universal-Transformer-style: same transform applied repeatedly with
  // shared weights. Tests whether parameter-sharing improves loss at fixed
  // FLOPs by acting as an inductive-bias regularizer.
  "model_dim": 256,
  "vocab_size": 1024,
  "seq_len": 1024,
  "parallel_residual": true,
  "logit_softcap": 30.0,
  "bigram_vocab_size": 3072,
  "bigram_dim": 64,
  "blocks": [
    {"type": "plain", "heads": 4, "qk_gain": 1.0, "weight_group": "attn_a"},
    {"type": "swiglu", "weight_group": "ffn_a"},
    {"type": "plain", "heads": 4, "qk_gain": 1.0, "weight_group": "attn_b"},
    {"type": "swiglu", "weight_group": "ffn_b"},
    {"type": "plain", "heads": 4, "qk_gain": 1.0, "weight_group": "attn_a"},
    {"type": "swiglu", "weight_group": "ffn_a"}
  ],
  "training": {
    "steps": 2000,
    "lr": 1e-3,
    "grad_clip": 1.0,
    "weight_decay": 0.04,
    "seed": 42,
    "batch_tokens": 4096,
    "optimizer": "muon",
    "muon_momentum": 0.95,
    "muon_backend_steps": 5
  }
}
