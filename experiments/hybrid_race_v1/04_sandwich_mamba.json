{
  "name": "04_sandwich_mamba",

  // Sandwich pattern: 2 attention + 2 mamba3 (linear) + 2 attention. Tests
  // the "capability injection" hypothesis from Paper A — quadratic attention
  // at the boundaries, linear attention in the middle for cheap mixing.
  // Different parameter mix than pure mamba or pure attention.
  "model_dim": 256,
  "vocab_size": 1024,
  "seq_len": 1024,
  "parallel_residual": false,
  "logit_softcap": 30.0,
  "bigram_vocab_size": 3072,
  "bigram_dim": 64,
  "blocks": [
    {"type": "plain", "heads": 4, "qk_gain": 1.0},
    {"type": "swiglu"},
    {"type": "mamba3"},
    {"type": "swiglu"},
    {"type": "mamba3"},
    {"type": "swiglu"},
    {"type": "plain", "heads": 4, "qk_gain": 1.0},
    {"type": "swiglu"}
  ],
  "training": {
    "steps": 2000,
    "lr": 1e-3,
    "grad_clip": 1.0,
    "weight_decay": 0.04,
    "seed": 42,
    "batch_tokens": 4096,
    "optimizer": "muon",
    "muon_momentum": 0.95,
    "muon_backend_steps": 5
  }
}
