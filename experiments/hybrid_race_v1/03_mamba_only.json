{
  "name": "03_mamba_only",

  // Pure mamba3 stack — constant-gate scan with FFT-optimized path. Tests
  // whether linear attention (state-space) alone, with no quadratic
  // attention, can match the baseline at this scale.
  "model_dim": 256,
  "vocab_size": 1024,
  "seq_len": 1024,
  "logit_softcap": 30.0,
  "bigram_vocab_size": 3072,
  "bigram_dim": 64,
  "blocks": [
    {"type": "mamba3"},
    {"type": "swiglu"},
    {"type": "mamba3"},
    {"type": "swiglu"},
    {"type": "mamba3"},
    {"type": "swiglu"}
  ],
  "training": {
    "steps": 2000,
    "lr": 1e-3,
    "grad_clip": 1.0,
    "weight_decay": 0.04,
    "seed": 42,
    "batch_tokens": 4096,
    "optimizer": "muon",
    "muon_momentum": 0.95,
    "muon_backend_steps": 5
  }
}
