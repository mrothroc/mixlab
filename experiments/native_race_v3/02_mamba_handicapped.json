{
  "name": "02_mamba_handicapped",

  // Mamba in attention's regime: SP-8192, T=1024, but with mamba-appropriate
  // optimizer (AdamW LR=3e-4, no SWA, no QAT). Isolates the optimizer-stack
  // contribution from the architectural-regime contribution.
  // Compare to v2's 02_mamba_optimized (Muon LR=1e-3 + SWA + QAT) → if this
  // config beats that one, the leader stack is actively hurting mamba.
  "model_dim": 320,
  "vocab_size": 8192,
  "seq_len": 1024,
  "logit_softcap": 30.0,
  "bigram_vocab_size": 3072,
  "bigram_dim": 80,
  "blocks": [
    {"type": "mamba3", "weight_group": "ssm_a"},
    {"type": "swiglu", "weight_group": "ffn_a"},
    {"type": "mamba3", "weight_group": "ssm_b"},
    {"type": "swiglu", "weight_group": "ffn_b"},
    {"type": "mamba3", "weight_group": "ssm_c"},
    {"type": "swiglu", "weight_group": "ffn_c"},
    {"type": "mamba3", "weight_group": "ssm_a"},
    {"type": "swiglu", "weight_group": "ffn_a"},
    {"type": "mamba3", "weight_group": "ssm_b"},
    {"type": "swiglu", "weight_group": "ffn_b"}
  ],
  "training": {
    "steps": 10000,
    "lr": 3e-4,
    "grad_clip": 1.0,
    "weight_decay": 0.01,
    "seed": 42,
    "batch_tokens": 4096,
    "optimizer": "adamw"
  }
}
