{
  "name": "deberta_relative_tiny",

  // Plain attention with DeBERTa-style disentangled relative position bias.
  "model_dim": 128,
  "vocab_size": 1024,
  "seq_len": 128,

  "blocks": [
    {"type": "plain", "heads": 4, "relative_attention": "deberta_p2c_c2p", "relative_attention_window": 128},
    {"type": "swiglu"},
    {"type": "plain", "heads": 4, "relative_attention": "deberta_p2c_c2p", "relative_attention_window": 128},
    {"type": "swiglu"}
  ],

  "training": {
    "steps": 100,
    "lr": 3e-4,
    "grad_clip": 1.0,
    "weight_decay": 0.01,
    "seed": 42,
    "batch_tokens": 1024
  }
}
