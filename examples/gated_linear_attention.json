      {"op": "add",     "inputs": ["x", "proj"],      "output": "x"}
    ]},
    {"type": "mlp", "activation": "leaky_relu_sq", "leaky_slope": 0.0}
  ],

  "training": {
    "steps": 100,
    "lr": 1e-3,
    "optimizer": "muon",
    "grad_clip": 1.0,
    "weight_decay": 0.04,
    "beta1": 0.9,
    "beta2": 0.95,
    "muon_momentum": 0.95,
    "muon_backend_steps": 5,
    "seed": 42,
    "batch_tokens": 2048
  }
}
