{
  "name": "recurrent_parallel",

  // Model dimensions
  "model_dim": 512,
  "vocab_size": 8192,         // 8192-token BPE vocabulary
  "seq_len": 2048,
  "mlp_mult": 3.0,            // FFN hidden dim = 3x model dim

  // Architecture features
  "logit_softcap": 30.0,      // Bound logits to [-30, 30] before loss
  "tie_embeddings": true,      // Head reuses embedding weights (saves D*V params)
  "parallel_residual": true,   // Attn + MLP see same input (parallel branches)
  "block_scales": true,        // Learned per-block output scaling
  "resid_mix": true,           // Learned blend of current state with original embedding
  "bigram_vocab_size": 4096,   // Hashed bigram embedding table size
  "bigram_dim": 128,

  // Depth recurrence: 5 block pairs, layers 3-4 reuse weights from layers 1-2.
  // This gives 10 effective layers with only 6 unique weight sets.
  "recurrence": [0, 1, 2, 3, 4, 5, 2, 3, 4, 5],

  "blocks": [
    // Each pair is (attention, feedforward). With parallel_residual=true,
    // both branches in a pair see the same pre-norm input.
    {"type": "plain", "heads": 8, "kv_heads": 4},  // GQA: 8 query heads, 4 KV heads
    {"type": "swiglu"},
    {"type": "plain", "heads": 8, "kv_heads": 4},
    {"type": "swiglu"},
    {"type": "plain", "heads": 8, "kv_heads": 4},
    {"type": "swiglu"},
    {"type": "plain", "heads": 8, "kv_heads": 4},
    {"type": "swiglu"},
    {"type": "plain", "heads": 8, "kv_heads": 4},
    {"type": "swiglu"}
  ],

  "training": {
    "steps": 3000,
    "lr": 3e-4,
    "grad_clip": 1.0,
    "weight_decay": 0.01,
    "beta1": 0.9,
    "beta2": 0.95,

    // Per-group learning rates (conservative for small batch)
    "embed_lr": 3e-4,
    "matrix_lr": 3e-4,          // Muon optimizer applies to matrix weights
    "scalar_lr": 3e-4,
    "muon_momentum": 0.95,      // Newton-Schulz momentum
    "muon_backend_steps": 5,    // Newton-Schulz iterations

    "seed": 42,
    "batch_tokens": 4096,

    // Test-time training: adapt weights on val data before scoring
    "ttt_steps": 1,             // 1 gradient step per val batch
    "ttt_lr": 1e-5              // Small LR for TTT adaptation
  }
}
