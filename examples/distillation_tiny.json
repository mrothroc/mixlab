{
  "name": "distillation_tiny",
  "model_dim": 64,
  "vocab_size": 256,
  "seq_len": 32,
  "blocks": [
    {"type": "plain", "heads": 4},
    {"type": "swiglu"},
    {"type": "plain", "heads": 4},
    {"type": "swiglu"}
  ],
  "training": {
    "steps": 200,
    "lr": 0.0003,
    "seed": 42,
    "batch_tokens": 1024,
    "objective": "causal",
    "distillation": {
      "teacher_checkpoints": [
        "runs/teacher_a.safetensors",
        "runs/teacher_b.safetensors"
      ],
      "teacher_configs": [
        "configs/teacher_a.json",
        "configs/teacher_b.json"
      ],
      "loss_weight_ce": 0.5,
      "loss_weight_kl": 0.5,
      "ensemble_strategy": "mean_logits"
    }
  }
}
