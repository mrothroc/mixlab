{
  "name": "multihead-mntp-span-pll-ranking-tiny",
  "model_dim": 32,
  "vocab_size": 128,
  "seq_len": 16,
  "mlp_mult": 2.0,
  "blocks": [
    {"type": "plain", "heads": 4},
    {"type": "geglu"},
    {"type": "plain", "heads": 4},
    {"type": "geglu"}
  ],
  "training": {
    "objective": "multihead",
    "steps": 200,
    "lr": 0.0003,
    "batch_tokens": 64,
    "seed": 42,
    "mlm_mask_prob": 0.15,
    "mlm_mask_token_id": 1,
    "export_head": "scorer",
    "minimal_pair": {
      "source": "jsonl",
      "path": "pairs.train.jsonl",
      "loss": "logistic",
      "margin": 1.0,
      "pair_batch_fraction": 1.0,
      "energy_aggregation": "differing_span",
      "score_source": "mlm_span_pll",
      "score_head": "scorer",
      "loss_weight": 1.0
    },
    "heads": [
      {
        "name": "scorer",
        "objective": "mntp",
        "loss_weight": 1.0,
        "output_head": "bert_mlm",
        "tie_embeddings": true,
        "final_norm": true
      },
      {
        "name": "aux",
        "objective": "causal",
        "loss_weight": 0.1,
        "output_head": "linear",
        "tie_embeddings": true,
        "final_norm": true
      }
    ]
  }
}
