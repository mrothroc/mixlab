{
  "name": "qk_norm_tiny",

  // Tiny causal transformer with learned Q/K RMSNorm in attention heads.
  "model_dim": 64,
  "vocab_size": 512,
  "seq_len": 64,

  "blocks": [
    {"type": "plain", "heads": 4, "qk_norm": true},
    {"type": "swiglu"},
    {"type": "plain", "heads": 4, "qk_norm": true},
    {"type": "swiglu"}
  ],

  "training": {
    "steps": 200,
    "lr": 3e-4,
    "grad_clip": 1.0,
    "weight_decay": 0.01,
    "seed": 42,
    "batch_tokens": 512
  }
}
