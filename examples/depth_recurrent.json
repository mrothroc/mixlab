{
  "name": "depth_recurrent_3x",

  // Same attention+FFN pair applied 3 times with shared weights.
  "model_dim": 64,
  "vocab_size": 1024,
  "seq_len": 128,

  "blocks": [
    {"type": "plain", "heads": 4, "weight_group": "attn"},
    {"type": "swiglu", "weight_group": "ffn"},
    {"type": "plain", "heads": 4, "weight_group": "attn"},
    {"type": "swiglu", "weight_group": "ffn"},
    {"type": "plain", "heads": 4, "weight_group": "attn"},
    {"type": "swiglu", "weight_group": "ffn"}
  ],

  "training": {
    "steps": 100,
    "lr": 3e-4,
    "grad_clip": 1.0,
    "weight_decay": 0.01,
    "seed": 42,
    "batch_tokens": 512
  }
}
