{
  "name": "mlstm_2L",

  // Two mLSTM token-mixer layers with separate SwiGLU channel mixing.
  "model_dim": 96,
  "vocab_size": 1024,
  "seq_len": 128,

  "blocks": [
    {"type": "mlstm", "heads": 6, "d_k": 16, "d_v": 16},
    {"type": "swiglu"},
    {"type": "mlstm", "heads": 6, "d_k": 16, "d_v": 16},
    {"type": "swiglu"}
  ],

  "training": {
    "steps": 50,
    "lr": 3e-4,
    "grad_clip": 1.0,
    "weight_decay": 0.01,
    "seed": 42,
    "batch_tokens": 512
  }
}
